---
import { loadContent } from '../lib/load';
import { withBase } from '../lib/url';
import { absUrl } from '../lib/canonical';
import { renderBold } from '../lib/inline-md';
import { contactIcon, ICON_EMAIL } from '../lib/icons';
import { SECTION_TITLES } from '../lib/labels';
import ExperienceItem from '../components/ExperienceItem.astro';
import YandexMetrika from '../components/YandexMetrika.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import FaviconLinks from '../components/FaviconLinks.astro';
import type { Localized, SkillItem } from '../schema/index';
import '../styles/landing.css';

const content = loadContent();
const base = import.meta.env.BASE_URL;

const { profile } = content;
const name = profile.name.ru; // язык документа по умолчанию — ru

// Tagline для hero: человеко-ориентированный general-вариант (с фолбэком).
const byPriority = [...content.summary.variants].sort((a, b) => b.priority - a.priority);
const tagline =
  content.summary.variants.find((v) => v.id === 'summary-general') ?? byPriority[0];

// Топ ключевых результатов по priority.
const results = [...content.achievements.items]
  .sort((a, b) => b.priority - a.priority)
  .slice(0, 6);

const skillGroups = [...content.skills.groups].sort((a, b) => b.priority - a.priority);

// Опыт — по дате начала по убыванию (новейшее сверху), как в основном резюме.
const experience = [...content.experience].sort((a, b) => b.start.localeCompare(a.start));

// Логотипы компаний для hero-полосы: уникальные, в порядке от новейшего опыта.
const companyLogos = experience
  .filter((e) => e.logo)
  .reduce<{ company: string; logo: string; expId: string }[]>((acc, e) => {
    if (!acc.some((c) => c.company === e.company)) {
      // expId — id первого (новейшего) места работы этой компании: якорь для скролла.
      acc.push({ company: e.company, logo: e.logo!, expId: e.id });
    }
    return acc;
  }, []);

// Личные увлечения — только для лендинга, по priority по убыванию.
const interests = [...content.interests.items].sort((a, b) => b.priority - a.priority);

// Продающая полоса цифр и лидерские тезисы — только лендинг, по priority по убыванию.
const stats = [...content.stats.items].sort((a, b) => b.priority - a.priority);
const theses = [...content.theses.items].sort((a, b) => b.priority - a.priority);

/** Навык: языко-нейтральная строка либо двуязычный термин. */
const isLocalized = (x: SkillItem): x is Localized => typeof x !== 'string';

const year = new Date().getFullYear();

// Контакт-иконки вынесены в src/lib/icons.ts (SVG, наследуют цвет чипа).

// Абсолютные URL для SEO/AI (портируемо: из Astro.site + base).
const site = Astro.site;
const pageUrl = absUrl(site, base, '');
const mdRu = absUrl(site, base, 'ru/resume.md');
const mdEn = absUrl(site, base, 'en/resume.md');
const llmsUrl = absUrl(site, base, 'llms.txt');
const jsonEn = absUrl(site, base, 'en/resume.json');
const ogImage = absUrl(site, base, profile.photo ?? 'favicon.svg');

// JSON-LD schema.org Person — факты прямо в HTML для ИИ/поисковиков.
const current = experience[0]; // новейшее место работы
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name.en,
  alternateName: profile.name.ru,
  jobTitle: profile.title.en,
  description: tagline.text.en,
  email: profile.email ? `mailto:${profile.email}` : undefined,
  url: pageUrl,
  address: profile.location
    ? { '@type': 'PostalAddress', addressLocality: profile.location.en }
    : undefined,
  sameAs: profile.links.map((l) => l.url),
  worksFor: current
    ? { '@type': 'Organization', name: current.company, url: current.companyUrl }
    : undefined,
  knowsLanguage: content.languages.items.map((l) => l.name.en),
  knowsAbout: profile.keywords?.en,
  alumniOf: content.education.items.map((e) => ({
    '@type': 'CollegeOrUniversity',
    name: e.institution.en,
  })),
};
---

<!doctype html>
<html lang="ru" data-lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <FaviconLinks />
    <title>{name} — резюме</title>
    <meta name="description" content={`${profile.title.ru} · ${tagline.text.ru}`} />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={`${name} — ${profile.title.ru}`} />
    <meta property="og:description" content={tagline.text.ru} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={name} />
    <meta name="twitter:description" content={tagline.text.ru} />
    <meta name="google-site-verification" content="av7FBCkzLKf20h9nwG9qptHSQe7fj6RBNwrTKG6zNT4" />
    <meta name="yandex-verification" content="5872f59cc3bd95f6" />
    <link rel="alternate" type="text/markdown" hreflang="ru" href={mdRu} />
    <link rel="alternate" type="text/markdown" hreflang="en" href={mdEn} />
    <link rel="alternate" type="text/plain" title="llms.txt" href={llmsUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      // Помечаем, что JS активен (включает сворачивание опыта и reveal-анимации).
      document.documentElement.classList.add('js');
      // Восстанавливаем выбранный язык до отрисовки тела — без мигания.
      (function () {
        try {
          var l = localStorage.getItem('landing-lang');
          if (l === 'en' || l === 'ru') {
            document.documentElement.dataset.lang = l;
            document.documentElement.setAttribute('lang', l);
          }
        } catch (e) {}
      })();
    </script>
    <YandexMetrika />
    <GoogleAnalytics />
  </head>
  <body>
    <header class="nav">
      <a class="brand" href={withBase(base)}>
        <span class="mono">SD</span>
        <span class="lang-ru">{profile.name.ru.split(' ')[1] ?? name}</span>
        <span class="lang-en">{profile.name.en.split(' ')[1] ?? profile.name.en}</span>
      </a>
      <div class="lang-toggle" role="group" aria-label="Language">
        <button type="button" data-set-lang="ru">RU</button>
        <button type="button" data-set-lang="en">EN</button>
      </div>
    </header>

    <main class="wrap">
      <!-- HERO -->
      <section class="hero">
        <div class="hero-grid">
          <div class="hero-main">
            <p class="eyebrow">
              <span class="lang-ru">Открыт к предложениям</span>
              <span class="lang-en">Open to opportunities</span>
            </p>
            <h1>
              <span class="lang-ru">{profile.name.ru}</span>
              <span class="lang-en">{profile.name.en}</span>
            </h1>
            <p class="title">
              <span class="lang-ru">{profile.title.ru}</span>
              <span class="lang-en">{profile.title.en}</span>
            </p>
            {
              profile.location && (
                <p class="location">
                  <span class="lang-ru">{profile.location.ru}</span>
                  <span class="lang-en">{profile.location.en}</span>
                </p>
              )
            }
            <p class="tagline">
              <span class="lang-ru">{tagline.text.ru}</span>
              <span class="lang-en">{tagline.text.en}</span>
            </p>

            <div class="contacts">
              {
                profile.email && (
                  <a class="chip" href={`mailto:${profile.email}`}>
                    <span class="ico" set:html={ICON_EMAIL} />
                    <span class="lang-ru">Почта</span>
                    <span class="lang-en">Email</span>
                  </a>
                )
              }
              {
                profile.links.map((l) => (
                  <a class="chip" href={l.url} target="_blank" rel="noopener noreferrer">
                    <span class="ico" set:html={contactIcon(l.kind)} />
                    {l.label}
                  </a>
                ))
              }
            </div>

            <div class="cta-row">
              <a class="btn btn-primary" href="#results">
                <span class="lang-ru">Ключевые результаты</span>
                <span class="lang-en">Key results</span>
              </a>
              <a class="btn btn-ghost" href="#experience">
                <span class="lang-ru">Опыт работы</span>
                <span class="lang-en">Experience</span>
              </a>
            </div>
          </div>

          <div class="hero-portrait">
            <div class="portrait-frame">
              {
                profile.photo ? (
                  <img
                    class="portrait-img"
                    src={withBase(base, profile.photo)}
                    alt={profile.name.ru}
                    loading="eager"
                  />
                ) : (
                  <div class="portrait-fallback" aria-hidden="true">
                    SD
                  </div>
                )
              }
            </div>
          </div>
        </div>

        {
          companyLogos.length > 0 && (
            <div class="logos">
              <span class="logos-label">
                <span class="lang-ru">Опыт в компаниях</span>
                <span class="lang-en">Experience at</span>
              </span>
              <div class="logos-row">
                {companyLogos.map((c) => (
                  <a class="logo" href={`#exp-${c.expId}`} title={c.company}>
                    <img src={withBase(base, c.logo)} alt={c.company} loading="lazy" />
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </section>

      <!-- ПОЛОСА ЦИФР -->
      {
        stats.length > 0 && (
          <section class="stats-band reveal" aria-label="Ключевые цифры">
            {stats.map((s) => (
              <div class="stat">
                <div class="stat-value">
                  <span class="lang-ru" data-count>
                    {s.value.ru}
                  </span>
                  <span class="lang-en" data-count>
                    {s.value.en}
                  </span>
                </div>
                <div class="stat-label">
                  <span class="lang-ru">{s.label.ru}</span>
                  <span class="lang-en">{s.label.en}</span>
                </div>
              </div>
            ))}
          </section>
        )
      }

      <!-- ТЕЗИСЫ -->
      {
        theses.length > 0 && (
          <section class="theses" aria-label="Принципы">
            {theses.map((t) => (
              <p class="thesis reveal">
                <span class="lang-ru" set:html={renderBold(t.text.ru)} />
                <span class="lang-en" set:html={renderBold(t.text.en)} />
              </p>
            ))}
          </section>
        )
      }

      <!-- РЕЗУЛЬТАТЫ -->
      <section class="section" id="results">
        <div class="section-head reveal">
          <span class="num">01</span>
          <h2>
            <span class="lang-ru">{SECTION_TITLES.achievements.ru}</span>
            <span class="lang-en">{SECTION_TITLES.achievements.en}</span>
          </h2>
        </div>
        <div class="results">
          {
            results.map((a) => (
              <article class="result reveal">
                <div class="body">
                  <span class="lang-ru" set:html={renderBold(a.text.ru)} />
                  <span class="lang-en" set:html={renderBold(a.text.en)} />
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <!-- ОПЫТ -->
      <section class="section" id="experience">
        <div class="section-head reveal">
          <span class="num">02</span>
          <h2>
            <span class="lang-ru">{SECTION_TITLES.experience.ru}</span>
            <span class="lang-en">{SECTION_TITLES.experience.en}</span>
          </h2>
        </div>
        <div class="timeline">
          {experience.map((e) => <ExperienceItem e={e} base={base} />)}
        </div>
      </section>

      <!-- НАВЫКИ -->
      <section class="section" id="skills">
        <div class="section-head reveal">
          <span class="num">03</span>
          <h2>
            <span class="lang-ru">{SECTION_TITLES.skills.ru}</span>
            <span class="lang-en">{SECTION_TITLES.skills.en}</span>
          </h2>
        </div>
        <div class="skill-groups">
          {
            skillGroups.map((g) => (
              <div class="skill-group reveal">
                <h3>
                  <span class="lang-ru">{g.name.ru}</span>
                  <span class="lang-en">{g.name.en}</span>
                </h3>
                <div class="tags">
                  {g.items.map((it) =>
                    isLocalized(it) ? (
                      <span class="tag">
                        <span class="lang-ru">{it.ru}</span>
                        <span class="lang-en">{it.en}</span>
                      </span>
                    ) : (
                      <span class="tag">{it}</span>
                    ),
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </section>

      {
        interests.length > 0 && (
          <section class="section" id="beyond">
            <div class="section-head reveal">
              <span class="num">04</span>
              <h2>
                <span class="lang-ru">Помимо работы</span>
                <span class="lang-en">Beyond work</span>
              </h2>
            </div>
            <p class="beyond-lead">
              <span class="lang-ru">
                Заряжаюсь там, где нужны фокус, баланс и немного смелости.
              </span>
              <span class="lang-en">
                I recharge where focus, balance and a bit of courage are required.
              </span>
            </p>
            <div class="interests">
              {interests.map((it) =>
                it.photo ? (
                  <button
                    class="interest interest-clickable reveal"
                    type="button"
                    data-photo={withBase(base, it.photo)}
                    data-caption-ru={it.label.ru}
                    data-caption-en={it.label.en}
                  >
                    {it.icon && (
                      <span class="interest-ico" aria-hidden="true">
                        {it.icon}
                      </span>
                    )}
                    <span class="lang-ru">{it.label.ru}</span>
                    <span class="lang-en">{it.label.en}</span>
                    <span class="interest-zoom" aria-hidden="true">⤢</span>
                  </button>
                ) : (
                  <span class="interest reveal">
                    {it.icon && (
                      <span class="interest-ico" aria-hidden="true">
                        {it.icon}
                      </span>
                    )}
                    <span class="lang-ru">{it.label.ru}</span>
                    <span class="lang-en">{it.label.en}</span>
                  </span>
                ),
              )}
            </div>
            {
              profile.instagram && (
                <a
                  class="beyond-link reveal"
                  href={profile.instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span class="beyond-link-ico" aria-hidden="true">
                    ✦
                  </span>
                  <span class="lang-ru">Больше личного</span>
                  <span class="lang-en">A bit more personal</span>
                  <span class="beyond-link-arrow" aria-hidden="true">
                    →
                  </span>
                </a>
              )
            }
          </section>
        )
      }

      <footer class="footer">
        <span class="copy">
          © {year}
          <span class="lang-ru">{profile.name.ru}</span>
          <span class="lang-en">{profile.name.en}</span>
        </span>
        <!-- Машиночитаемая версия: видимый указатель для ИИ-ассистентов
             (которые читают рендер, а не <head>) и сигнал «как данные» для людей. -->
        <span class="machine">
          <span class="lang-ru">Это резюме доступно как данные:</span>
          <span class="lang-en">This resume is available as data:</span>
          <a href={llmsUrl}>llms.txt</a>
          <span class="sep" aria-hidden="true">·</span>
          <a href={mdEn}>Markdown</a>
          <span class="sep" aria-hidden="true">·</span>
          <a href={jsonEn}>JSON Resume</a>
        </span>
      </footer>
    </main>

    <!-- Лайтбокс для фото увлечений (наполняется по клику на чип). -->
    <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true">
      <button class="lightbox-close" type="button" aria-label="Close">×</button>
      <figure class="lightbox-fig">
        <img class="lightbox-img" src="" alt="" />
        <figcaption class="lightbox-cap"></figcaption>
      </figure>
    </div>

    <script is:inline>
      (function () {
        var html = document.documentElement;
        function set(l) {
          html.dataset.lang = l;
          html.setAttribute('lang', l);
          try {
            localStorage.setItem('landing-lang', l);
          } catch (e) {}
        }
        document.querySelectorAll('[data-set-lang]').forEach(function (b) {
          b.addEventListener('click', function () {
            set(b.getAttribute('data-set-lang'));
          });
        });

        var reduce =
          window.matchMedia &&
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // --- Сворачивание опыта: всё видимо без JS; здесь сворачиваем и вешаем тоггл.
        document.querySelectorAll('.tl-toggle').forEach(function (btn) {
          var rest = btn.parentElement.querySelector('.tl-rest');
          if (!rest) return;
          rest.classList.add('is-collapsed');
          rest.style.maxHeight = '0px';
          btn.addEventListener('click', function () {
            var open = btn.getAttribute('aria-expanded') === 'true';
            if (open) {
              // Свернуть: фиксируем текущую высоту, затем уводим в 0 (для анимации).
              rest.style.maxHeight = rest.scrollHeight + 'px';
              requestAnimationFrame(function () {
                rest.classList.add('is-collapsed');
                rest.style.maxHeight = '0px';
              });
              btn.setAttribute('aria-expanded', 'false');
            } else {
              rest.classList.remove('is-collapsed');
              rest.style.maxHeight = rest.scrollHeight + 'px';
              btn.setAttribute('aria-expanded', 'true');
            }
          });
          // После разворота снимаем фиксированную высоту — чтобы контент мог
          // переразмечаться (напр. при переключении языка).
          rest.addEventListener('transitionend', function (ev) {
            if (ev.propertyName === 'max-height' && !rest.classList.contains('is-collapsed')) {
              rest.style.maxHeight = 'none';
            }
          });
        });

        // --- Появление при скролле.
        var revealables = document.querySelectorAll('.reveal');
        if (reduce || !('IntersectionObserver' in window)) {
          revealables.forEach(function (el) {
            el.classList.add('in');
          });
        } else {
          var io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('in');
                  io.unobserve(entry.target);
                }
              });
            },
            { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
          );
          revealables.forEach(function (el) {
            io.observe(el);
          });
        }

        // --- Count-up для полосы цифр: докручиваем числовой префикс от 0.
        // Без анимации значения уже в DOM (важно для no-JS/reduce-motion/SEO).
        var band = document.querySelector('.stats-band');
        if (band && !reduce && 'IntersectionObserver' in window) {
          // У каждого числа парсим ведущий целый префикс: «50+»→50, «91%»→91,
          // «10+ лет»→10. Если целого префикса нет («1,5×») — оставляем как есть.
          var counters = [];
          band.querySelectorAll('[data-count]').forEach(function (el) {
            var full = el.textContent;
            var m = /^(\d+)/.exec(full.trim());
            if (!m) return;
            var suffix = full.trim().slice(m[1].length); // «+», «%», « лет»…
            // Дробные («1,5×», «1.5×») не крутим — 0→1 смотрится странно.
            if (/^[.,]/.test(suffix)) return;
            var target = parseInt(m[1], 10);
            counters.push({ el: el, target: target, suffix: suffix });
            el.textContent = '0' + suffix;
          });
          if (counters.length) {
            var DURATION = 850;
            var animate = function (start) {
              var step = function (now) {
                var p = Math.min((now - start) / DURATION, 1);
                var eased = 1 - Math.pow(1 - p, 3); // ease-out cubic
                counters.forEach(function (c) {
                  c.el.textContent = Math.round(eased * c.target) + c.suffix;
                });
                if (p < 1) requestAnimationFrame(step);
              };
              requestAnimationFrame(step);
            };
            var cio = new IntersectionObserver(
              function (entries) {
                entries.forEach(function (entry) {
                  if (entry.isIntersecting) {
                    cio.unobserve(entry.target);
                    requestAnimationFrame(function (t) {
                      animate(t);
                    });
                  }
                });
              },
              { threshold: 0.35 },
            );
            cio.observe(band);
          }
        }

        // --- Лайтбокс фото увлечений.
        var lb = document.getElementById('lightbox');
        if (lb) {
          var lbImg = lb.querySelector('.lightbox-img');
          var lbCap = lb.querySelector('.lightbox-cap');
          var lastFocused = null;
          function openLightbox(src, capRu, capEn, alt) {
            lbImg.setAttribute('src', src);
            lbImg.setAttribute('alt', alt || '');
            lbCap.innerHTML = '';
            var sru = document.createElement('span');
            sru.className = 'lang-ru';
            sru.textContent = capRu || '';
            var sen = document.createElement('span');
            sen.className = 'lang-en';
            sen.textContent = capEn || '';
            lbCap.appendChild(sru);
            lbCap.appendChild(sen);
            lb.classList.add('open');
            lb.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
          }
          function closeLightbox() {
            lb.classList.remove('open');
            lb.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
            lbImg.setAttribute('src', '');
            if (lastFocused) lastFocused.focus();
          }
          document.querySelectorAll('.interest-clickable').forEach(function (btn) {
            btn.addEventListener('click', function () {
              lastFocused = btn;
              openLightbox(
                btn.getAttribute('data-photo'),
                btn.getAttribute('data-caption-ru'),
                btn.getAttribute('data-caption-en'),
                btn.getAttribute('data-caption-' + (html.dataset.lang || 'ru')),
              );
            });
          });
          lb.addEventListener('click', function (ev) {
            // Клик по фону/крестику (не по самому фото) — закрыть.
            if (ev.target === lb || ev.target.classList.contains('lightbox-close')) {
              closeLightbox();
            }
          });
          document.addEventListener('keydown', function (ev) {
            if (ev.key === 'Escape' && lb.classList.contains('open')) closeLightbox();
          });
        }
      })();
    </script>
  </body>
</html>
