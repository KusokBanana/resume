---
import { loadContent, loadTargets } from '../../lib/load';
import { compose, targetLangPairs } from '../../lib/compose';
import { variantSlug } from '../../lib/slug';
import { UI } from '../../lib/labels';
import Resume from '../../components/Resume.astro';
import '../../styles/resume.css';

export function getStaticPaths() {
  const content = loadContent();
  const targets = loadTargets();
  return targetLangPairs(targets).map(({ target, lang }) => ({
    params: { target: target.id, lang },
    props: { doc: compose(content, target, lang), sections: target.sections },
  }));
}

const { doc, sections } = Astro.props;
const base = import.meta.env.BASE_URL;
const slug = variantSlug(doc.meta.targetId, doc.meta.language);
const lang = doc.meta.language;
const other = lang === 'ru' ? 'en' : 'ru';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{doc.profile.name} — {doc.meta.label} ({lang.toUpperCase()})</title>
    <meta name="description" content={doc.summary ?? doc.profile.title} />
  </head>
  <body>
    <nav class="toolbar">
      <a href={`${base}`}>← {UI.variants[lang]}</a>
      <a href={`${base}${doc.meta.targetId}/${other}`}>{other.toUpperCase()}</a>
      <span class="spacer"></span>
      <a href={`${base}generated/${slug}.pdf`} download>{UI.downloadPdf[lang]}</a>
      <a href={`${base}generated/${slug}.md`} download>{UI.downloadMd[lang]}</a>
    </nav>
    <main class="page">
      <Resume doc={doc} sections={sections} />
    </main>
  </body>
</html>
