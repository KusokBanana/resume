---
// Набор фавиконок. SVG — для современных браузеров; PNG + favicon.ico — для
// поисковых роботов (Яндекс/Google не грузят SVG) и легаси. Пути через withBase
// (см. src/lib/url.ts), base берём здесь, чтобы компонент был самодостаточным.
import { withBase } from '../lib/url';
const base = import.meta.env.BASE_URL;
---
<link rel="icon" type="image/svg+xml" href={withBase(base, 'favicon.svg')} />
<link rel="icon" type="image/png" sizes="96x96" href={withBase(base, 'favicon-96x96.png')} />
<link rel="icon" type="image/png" sizes="32x32" href={withBase(base, 'favicon-32x32.png')} />
<link rel="icon" type="image/png" sizes="16x16" href={withBase(base, 'favicon-16x16.png')} />
<link rel="icon" href={withBase(base, 'favicon.ico')} sizes="any" />
<link rel="apple-touch-icon" sizes="180x180" href={withBase(base, 'apple-touch-icon.png')} />
